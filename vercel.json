{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/styles/(.*)", "dest": "/styles/$1" },
    { "src": "/scripts/(.*)", "dest": "/scripts/$1" },
    
    /* ADD THIS LINE: It tells Vercel to stop looking if the file exists physically */
    { "handle": "filesystem" },

    { "src": "/admin/login", "dest": "/api/login.php" },
    { "src": "/admin/products", "dest": "/api/admin.php" },
    { "src": "/admin/orders", "dest": "/api/admin_orders.php" },
    { "src": "/admin/setup", "dest": "/api/setup.php" },
    { "src": "/admin/staff", "dest": "/api/admin_staff.php" },
    { "src": "/admin/settings", "dest": "/api/change_password.php" },
    { "src": "/logout", "dest": "/api/logout.php" },
    
    /* Catch-all for the storefront */
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
