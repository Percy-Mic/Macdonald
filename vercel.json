{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    /* 1. ALLOW DIRECT ACCESS TO STATIC ASSETS FIRST */
    { "handle": "filesystem" },

    /* 2. SPECIFIC CLEAN URLS FOR ADMIN */
    { "src": "/admin/login", "dest": "/api/login.php" },
    { "src": "/admin/products", "dest": "/api/admin.php" },
    { "src": "/admin/orders", "dest": "/api/admin_orders.php" },
    { "src": "/admin/staff", "dest": "/api/admin_staff.php" },
    { "src": "/admin/settings", "dest": "/api/change_password.php" },
    { "src": "/logout", "dest": "/api/logout.php" },

    /* 3. API ENDPOINTS */
    { "src": "/api/(.*)", "dest": "/api/$1" },

    /* 4. CATCH-ALL FOR STOREFRONT (MUST BE LAST) */
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
