{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/styles/(.*)", "dest": "/styles/$1" },
    { "src": "/scripts/(.*)", "dest": "/scripts/$1" },
    { "handle": "filesystem" },
    { "src": "/admin/login", "dest": "/api/login.php" },
    { "src": "/admin/orders", "dest": "/api/admin_orders.php" },
    { "src": "/logout", "dest": "/api/logout.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
